# LiveKit agent environment variables

# Supabase (service-role — used by agent for DB reads/writes)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Xero integration (Phase 55) — SAME values as the Voco Next.js side
# (agent reads them server-side to refresh access tokens against identity.xero.com).
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
