# LiveKit agent environment variables
#
# Complete list of every env var the Python agent + webhook service read.
# Copy to .env and fill in. Values left blank below are required unless the
# group comment says otherwise.

# ── Supabase (service-role — used by agent for DB reads/writes) ──────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase S3 (call-recording upload to Supabase Storage's S3 endpoint) ────
# REGION/ENDPOINT have code defaults (ap-northeast-1 / empty) but should be set
# explicitly in production.
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_REGION=
SUPABASE_S3_ENDPOINT=

# ── LiveKit (read implicitly by the livekit-agents worker + SIP dispatch) ────
# The worker SDK reads LIVEKIT_URL / LIVEKIT_API_KEY / LIVEKIT_API_SECRET.
# LIVEKIT_SIP_URI is the SIP URI Twilio dials into (code default:
# sip:voco@sip.livekit.cloud).
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_URI=

# ── Twilio (SIP trunk, owner-pickup dial, SMS, webhook signature verify) ─────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Stripe (overage usage reporting via Billing Meters) ──────────────────────
STRIPE_SECRET_KEY=

# ── Google ───────────────────────────────────────────────────────────────────
# IMPORTANT: two DIFFERENT Google keys with different purposes:
#   GOOGLE_API_KEY      — Gemini 3.1 Flash Live realtime model + Gemini TTS
#                         (read implicitly by the livekit google plugin).
#   GOOGLE_MAPS_API_KEY — Address Validation API (validate_address). Missing →
#                         verdict='skipped' (graceful degradation).
GOOGLE_API_KEY=
GOOGLE_MAPS_API_KEY=
# Google Calendar OAuth (calendar sync token refresh)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft / Outlook Calendar OAuth (calendar sync token refresh) ─────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Groq (triage layer-2 LLM classifier) ─────────────────────────────────────
GROQ_API_KEY=

# ── Sentry (error reporting; optional — unset disables Sentry) ───────────────
SENTRY_DSN=

# ── Resend (transactional owner email notifications) ─────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Xero integration (Phase 55) — SAME values as the Voco Next.js side ───────
# (agent reads them server-side to refresh access tokens against identity.xero.com).
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# ── Jobber integration — SAME values as the Voco Next.js side ────────────────
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=

# ── App config ───────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL — base URL of the Next.js app (used to build links).
# PYTHON_ENV — "production" enables prod behaviors (e.g. Sentry env tag).
# ALLOW_UNSIGNED_WEBHOOKS — "true" bypasses Twilio signature verification
#   (DEV ONLY — never set in production).
# RAILWAY_WEBHOOK_URL — public base URL of this webhook service (Twilio callbacks).
NEXT_PUBLIC_APP_URL=
PYTHON_ENV=
ALLOW_UNSIGNED_WEBHOOKS=
RAILWAY_WEBHOOK_URL=
